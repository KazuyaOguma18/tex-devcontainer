{
  "name": "tex-devcontainer",
  "version": "1.0.0",
  "description": "LaTeX project with textlint for Japanese and English proofreading",
  "private": true,
  "scripts": {
    "lint": "textlint project/**/*.tex *.md",
    "lint:fix": "textlint --fix project/**/*.tex *.md"
  },
  "devDependencies": {
    "textlint": "^14.0.4",
    "textlint-rule-preset-ja-technical-writing": "^10.0.1",
    "textlint-rule-preset-japanese": "^10.0.3",
    "textlint-rule-prh": "^6.0.0",
    "textlint-rule-terminology": "^5.0.1",
    "textlint-rule-write-good": "^2.0.0",
    "textlint-filter-rule-comments": "^1.2.2",
    "@textlint-ja/textlint-rule-no-synonyms": "^1.3.0",
    "textlint-rule-no-mix-dearu-desumasu": "^5.0.0",
    "textlint-rule-no-doubled-joshi": "^5.0.1",
    "textlint-rule-max-ten": "^5.0.0"
  }
}
